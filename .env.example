# PostgreSQL connection string
# Format: postgres://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE_NAME>

# Soroban RPC endpoint URL
# Format: https://<domain> or http://<ip>:<port>
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Ledger sequence number to start indexing from (0 = latest)
# Format: integer (e.g., 0, 123456)
START_LEDGER=0

# HTTP server port to listen on
# Format: integer (e.g., 3000, 8080)
PORT=3000

# Rust logging level configuration
# Format: string (trace, debug, info, warn, error)
RUST_LOG=info
